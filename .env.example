# Опционально: endpoint backend-прокси (API Gateway -> Workflows)
WORKFLOW_RUN_ENDPOINT=
# Опционально: whitelist хостов для endpoint из Settings (через запятую)
# По умолчанию разрешены:
# - serverless-workflows.api.cloud.yandex.net
# - *.apigw.yandexcloud.net
# - localhost/127.0.0.1/::1
WORKFLOW_ALLOWED_HOSTS=
# Опционально: таймаут внешних вызовов из /api/run-triage (мс)
WORKFLOW_FETCH_TIMEOUT_MS=30000

# Опционально: прямой режим Workflows API из /api/run-triage
WORKFLOW_ID=
YANDEX_IAM_TOKEN=
WORKFLOW_API_BASE=https://serverless-workflows.api.cloud.yandex.net/workflows/v1
